set -e
if [ -d /run/systemd/system ]; then
    systemctl daemon-reload || true
fi
# Deliberately do NOT delete config/state + venv on remove (only on purge).
if [ "$1" = "purge" ]; then
    rm -rf /opt/linuxmuster-squid
    rm -rf /etc/linuxmuster-squid /var/lib/linuxmuster-squid
fi
exit 0
