#!/bin/sh
# SPDX-FileCopyrightText: Kevin Stenzel
# SPDX-License-Identifier: GPL-3.0-or-later
set -e

# System-User (in docker-Gruppe für den Socket-Zugriff)
if ! getent passwd lmnsquid >/dev/null 2>&1; then
    adduser --system --group --no-create-home \
        --home /var/lib/linuxmuster-squid lmnsquid
fi
if getent group docker >/dev/null 2>&1; then
    usermod -aG docker lmnsquid || true
fi

mkdir -p /etc/linuxmuster-squid/secrets /var/lib/linuxmuster-squid/instances

# Config mit zufälligem API-Token (nur, wenn noch nicht vorhanden)
CFG=/etc/linuxmuster-squid/config.yml
if [ ! -f "$CFG" ]; then
    TOKEN="$(openssl rand -hex 32)"
    # umask 077 -> Datei entsteht mit 0600 (kein 0644-Fenster für den API-Token).
    ( umask 077
      cat > "$CFG" <<EOF
api_token: "$TOKEN"
instances_dir: /var/lib/linuxmuster-squid/instances
secrets_dir: /etc/linuxmuster-squid/secrets
bind_host: 127.0.0.1
bind_port: 8080
api_url: http://127.0.0.1:8080
EOF
    )
    chmod 600 "$CFG"
fi

chown -R lmnsquid:lmnsquid /etc/linuxmuster-squid /var/lib/linuxmuster-squid
chmod 700 /etc/linuxmuster-squid/secrets

# instances_dir als git-Repo initialisieren -> Store-Änderungen werden als Change-Log
# committet (Store._git ist best-effort und braucht ein Repo + Identität).
INST_DIR=/var/lib/linuxmuster-squid/instances
if command -v git >/dev/null 2>&1 && [ ! -d "$INST_DIR/.git" ]; then
    git -C "$INST_DIR" init -q || true
    git -C "$INST_DIR" config user.name  "linuxmuster-squid" || true
    git -C "$INST_DIR" config user.email "lmnsquid@localhost" || true
    chown -R lmnsquid:lmnsquid "$INST_DIR/.git" || true
fi

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload || true
    systemctl enable linuxmuster-squid.service || true
    # Frisch-Installation ($2 leer) -> start; Upgrade ($2 = Vorversion) -> try-restart,
    # damit der laufende Dienst den neuen Code aus dem venv WIRKLICH lädt (enable --now
    # wäre auf einem bereits laufenden Dienst ein No-op -> alter Code bliebe aktiv).
    if [ -n "${2:-}" ]; then
        systemctl try-restart linuxmuster-squid.service || true
    else
        systemctl start linuxmuster-squid.service || true
    fi
fi

exit 0
