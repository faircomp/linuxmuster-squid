#!/bin/sh
# SPDX-FileCopyrightText: Kevin Stenzel
# SPDX-License-Identifier: GPL-3.0-or-later
set -e

# System user (in the docker group for socket access)
if ! getent passwd lmnsquid >/dev/null 2>&1; then
    adduser --system --group --no-create-home \
        --home /var/lib/linuxmuster-squid lmnsquid
fi
if getent group docker >/dev/null 2>&1; then
    usermod -aG docker lmnsquid || true
fi

mkdir -p /etc/linuxmuster-squid/secrets /var/lib/linuxmuster-squid/instances

# Config with a random API token (only if it does not exist yet)
CFG=/etc/linuxmuster-squid/config.yml
if [ ! -f "$CFG" ]; then
    TOKEN="$(openssl rand -hex 32)"
    # umask 077 -> file is created with 0600 (no 0644 window for the API token).
    ( umask 077
      cat > "$CFG" <<EOF
api_token: "$TOKEN"
instances_dir: /var/lib/linuxmuster-squid/instances
secrets_dir: /etc/linuxmuster-squid/secrets
bind_host: 127.0.0.1
bind_port: 8080
api_url: http://127.0.0.1:8080
EOF
    )
    chmod 600 "$CFG"
fi

chown -R lmnsquid:lmnsquid /etc/linuxmuster-squid /var/lib/linuxmuster-squid
chmod 700 /etc/linuxmuster-squid/secrets

# Initialize instances_dir as a git repo -> Store changes are committed as a change log
# (Store._git is best-effort and needs a repo + identity).
INST_DIR=/var/lib/linuxmuster-squid/instances
if command -v git >/dev/null 2>&1 && [ ! -d "$INST_DIR/.git" ]; then
    git -C "$INST_DIR" init -q || true
    git -C "$INST_DIR" config user.name  "linuxmuster-squid" || true
    git -C "$INST_DIR" config user.email "lmnsquid@localhost" || true
    chown -R lmnsquid:lmnsquid "$INST_DIR/.git" || true
fi

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload || true
    systemctl enable linuxmuster-squid.service || true
    # Fresh install ($2 empty) -> start; upgrade ($2 = previous version) -> try-restart,
    # so the running service REALLY loads the new code from the venv (enable --now
    # would be a no-op on an already-running service -> old code would stay active).
    if [ -n "${2:-}" ]; then
        systemctl try-restart linuxmuster-squid.service || true
    else
        systemctl start linuxmuster-squid.service || true
    fi
    # On upgrade, lift all running instances onto this package's pinned default
    # image (best-effort; each instance updates with its own health-check
    # auto-rollback). Wait briefly for the restarted API; never fail the install.
    if [ -n "${2:-}" ]; then
        LMN=/opt/linuxmuster-squid/venv/bin/lmnsquid
        i=0
        while [ "$i" -lt 30 ]; do
            "$LMN" health >/dev/null 2>&1 && break
            i=$((i + 1)); sleep 1
        done
        "$LMN" update-all >/dev/null 2>&1 || true
    fi
fi

exit 0
