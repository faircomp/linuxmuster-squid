// WPAD/PAC-Beispiel (optional, als Fallback zur expliziten GPO-Zuweisung).
// WICHTIG: WPAD kann NICHT nach Benutzer/Rolle unterscheiden — die Lehrer/Schüler-
// Trennung erzwingt die AD-Gruppen-ACL am Proxy (server-seitig). Für eine Vorauswahl
// pro Raum/Subnetz ggf. isInNet() nutzen. Kein wpad-PTR anlegen (bricht Linux-SSO).
function FindProxyForURL(url, host) {
    // Intern immer direkt (LDAP, LINBO, WebUI, interne Dienste)
    if (isPlainHostName(host) ||
        dnsDomainIs(host, ".linuxmuster.meineschule.de") ||
        isInNet(host, "10.0.0.0", "255.0.0.0")) {
        return "DIRECT";
    }
    // Beispiel: Schüler-Subnetz -> Schüler-Proxy, sonst Lehrer-Proxy.
    if (isInNet(myIpAddress(), "10.2.0.0", "255.255.0.0")) {
        return "PROXY proxy-students.linuxmuster.meineschule.de:3128; DIRECT";
    }
    return "PROXY proxy-teachers.linuxmuster.meineschule.de:3128; DIRECT";
}
