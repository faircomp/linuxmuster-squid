// WPAD/PAC example (optional, as a fallback to explicit GPO assignment).
// IMPORTANT: WPAD can NOT distinguish by user/role -- the teacher/student
// split is enforced by the AD group ACL at the proxy (server-side). For a
// pre-selection per room/subnet, use isInNet() if needed. Do not create a
// wpad PTR record (it breaks Linux SSO).
function FindProxyForURL(url, host) {
    // Internal traffic always direct (LDAP, LINBO, WebUI, internal services)
    if (isPlainHostName(host) ||
        dnsDomainIs(host, ".linuxmuster.meineschule.de") ||
        isInNet(host, "10.0.0.0", "255.0.0.0")) {
        return "DIRECT";
    }
    // Example: student subnet -> student proxy, otherwise teacher proxy.
    if (isInNet(myIpAddress(), "10.2.0.0", "255.255.0.0")) {
        return "PROXY proxy-students.linuxmuster.meineschule.de:3128; DIRECT";
    }
    return "PROXY proxy-teachers.linuxmuster.meineschule.de:3128; DIRECT";
}
